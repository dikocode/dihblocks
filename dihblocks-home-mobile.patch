+.game-home-actions { display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }
+.game-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 14px; }
+.game-card { display: flex; flex-direction: column; justify-content: space-between; gap: 22px; min-height: 190px; padding: 20px; background: rgba(22,33,62,0.82); border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: 0 12px 30px rgba(0,0,0,0.18); transition: transform .2s, border-color .2s, background .2s; }
+.game-card:hover { transform: translateY(-3px); border-color: rgba(233,69,96,0.7); background: rgba(22,33,62,0.98); }
+.game-card.featured { border-color: rgba(245,166,35,0.55); background: linear-gradient(145deg, rgba(245,166,35,0.16), rgba(22,33,62,0.9) 55%); }
+.game-card h2 { font-size: 1.12rem; margin: 6px 0; }
+.game-card p { color: var(--muted); font-size: 0.82rem; line-height: 1.5; }
+.game-card-meta { color: var(--muted); font-size: 0.72rem; margin-top: 5px; }
+.game-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; }
+.game-card-icon { font-size: 1.6rem; }
+.game-card-actions { display: flex; gap: 8px; }
+.game-loading, .game-empty { grid-column: 1 / -1; padding: 56px 20px; color: var(--muted); text-align: center; border: 1px dashed var(--border); border-radius: var(--radius-lg); }
+.game-home-footer { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-top: 30px; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.09); color: var(--muted); font-size: 0.8rem; }
