+/* ── Game Hub ──────────────────────────────────────────── */
+#game-home {
+  position: absolute; inset: 0; z-index: 1000; overflow-y: auto;
+  background: radial-gradient(circle at 15% 10%, rgba(233,69,96,0.2), transparent 34%), radial-gradient(circle at 90% 20%, rgba(245,166,35,0.15), transparent 30%), linear-gradient(145deg, #12152b 0%, #0f3460 100%);
+}
+.game-home-shell { width: min(1120px, 100%); min-height: 100%; margin: 0 auto; padding: clamp(28px, 6vw, 72px) clamp(18px, 5vw, 64px) 28px; }
+.game-home-header { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 32px; }
+.game-home-header h1 { font-size: clamp(2rem, 5vw, 4rem); line-height: 0.95; letter-spacing: -2px; margin: 8px 0 12px; }
+.game-home-header p { color: var(--muted); max-width: 520px; font-size: 1rem; }
